];

class BossManager {
  // ✅ CRITICAL FIX: Filter bosses by player level
  static getAvailableBosses(playerLevel) {
    return bossTemplates.filter(boss => {
      // Players can fight bosses at their minimum level
      // But can only fight bosses within +5 levels of their current level
      return boss.minLevel <= playerLevel && boss.minLevel >= (playerLevel - 5);
    });
  }

  static generateBoss(template, playerLevel) {
    // Scale boss stats based on player level
    const levelDiff = Math.max(0, playerLevel - template.minLevel);
    const scaleFactor = 1 + (levelDiff * 0.1);

    return {
      name: template.name,
      rank: template.rank,
      emoji: template.emoji,
      title: template.title,
      abilities: [...template.abilities],
      minLevel: template.minLevel,
      stats: {
        hp: Math.floor(template.baseHp * scaleFactor),
        maxHp: Math.floor(template.baseHp * scaleFactor),
        atk: Math.floor(template.baseAtk * scaleFactor),
        def: Math.floor(template.baseDef * scaleFactor)
      },
      baseXPReward: template.baseXPReward,
      baseCrystalReward: template.baseCrystalReward,
      baseGoldReward: template.baseGoldReward
    };
  }

  static calculateBossRewards(boss, playerLevel) {
    const levelBonus = 1 + (playerLevel * 0.05);
    
    return {
      xp: Math.floor(boss.baseXPReward * levelBonus),
      crystals: Math.floor(boss.baseCrystalReward * levelBonus),
      gold: Math.floor(boss.baseGoldReward * levelBonus)
    };
  }

  static generateBossLoot(boss, playerLevel) {
    const loot = [];
    const rarityChances = {
      'F': { common: 0.7, uncommon: 0.25, rare: 0.05, epic: 0, legendary: 0 },
      'E': { common: 0.6, uncommon: 0.3, rare: 0.08, epic: 0.02, legendary: 0 },
      'D': { common: 0.5, uncommon: 0.3, rare: 0.15, epic: 0.05, legendary: 0 },
      'C': { common: 0.4, uncommon: 0.3, rare: 0.2, epic: 0.08, legendary: 0.02 },
      'B': { common: 0.3, uncommon: 0.3, rare: 0.25, epic: 0.12, legendary: 0.03 },
      'A': { common: 0.2, uncommon: 0.3, rare: 0.3, epic: 0.15, legendary: 0.05 },
      'S': { common: 0.1, uncommon: 0.2, rare: 0.3, epic: 0.25, legendary: 0.15 },
      'SS': { common: 0.05, uncommon: 0.15, rare: 0.25, epic: 0.35, legendary: 0.20 },
      'National': { common: 0, uncommon: 0.1, rare: 0.2, epic: 0.4, legendary: 0.30 },
      'Beyond': { common: 0, uncommon: 0, rare: 0.1, epic: 0.3, legendary: 0.60 }
    };

    const chances = rarityChances[boss.rank] || rarityChances['F'];
    const numItems = boss.rank === 'National' || boss.rank === 'Beyond' ? 3 : boss.rank === 'SS' ? 2 : 1;

    for (let i = 0; i < numItems; i++) {
      const roll = Math.random();
      let rarity = 'common';
      let cumulative = 0;

      for (const [key, value] of Object.entries(chances)) {
        cumulative += value;
        if (roll <= cumulative) {
          rarity = key;
          break;
        }
      }

      const itemTypes = ['Weapon', 'Armor', 'Accessory', 'Potion', 'Core'];
      const itemType = itemTypes[Math.floor(Math.random() * itemTypes.length)];
      
      loot.push({
        name: `${boss.rank}-Rank ${itemType}`,
        type: itemType,
        rarity: rarity,
        from: boss.name
      });
    }

    return loot;
  }

  // ✅ NEW: Function for co-op raids (generateRaidBoss)
  static generateRaidBoss(minLevel) {
    // Get bosses available for this level
    const availableBosses = this.getAvailableBosses(minLevel);
    
    if (availableBosses.length === 0) {
      // Fallback to highest available boss
      const highestBoss = bossTemplates[bossTemplates.length - 1];
      return this.generateBoss(highestBoss, minLevel);
    }

    // Select random boss
    const template = availableBosses[Math.floor(Math.random() * availableBosses.length)];
    const boss = this.generateBoss(template, minLevel);
    
    // Scale up for raid (3x stats)
    boss.stats.hp *= 3;
    boss.stats.maxHp *= 3;
    boss.stats.atk = Math.floor(boss.stats.atk * 1.5);
    boss.stats.def = Math.floor(boss.stats.def * 1.5);
    
    return boss;
  }
}

module.exports = BossManager;